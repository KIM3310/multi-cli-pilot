{
  "name": "multi-cli-pilot",
  "version": "2.0.0",
  "description": "Multi-agent orchestration harness for CLI coding agents (Gemini, Qwen) -- prompts, workflows, team coordination, MCP, HUD.",
  "author": "Doeon Kim",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "mcp": "dist/cli/index.js",
    "multi-cli-pilot": "dist/cli/index.js",
    "gp": "dist/cli/index.js",
    "gemini-pilot": "dist/cli/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "prompts",
    "workflows",
    "AGENTS.md",
    "Install-Mac.command",
    "Install-Windows.bat",
    "Install-Linux.sh"
  ],
  "scripts": {
    "prebuild": "rm -f tsconfig.tsbuildinfo",
    "build": "tsc",
    "dev": "tsc --watch",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/",
    "format": "biome format src/ --write",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "yaml": "^2.7.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^3.1.2",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "keywords": [
    "gemini",
    "gemini-cli",
    "qwen",
    "qwen-cli",
    "multi-agent",
    "orchestration",
    "ai",
    "workflow",
    "prompt-engineering",
    "mcp"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KIM3310/multi-cli-pilot.git"
  },
  "homepage": "https://github.com/KIM3310/multi-cli-pilot#readme",
  "bugs": {
    "url": "https://github.com/KIM3310/multi-cli-pilot/issues"
  }
}
