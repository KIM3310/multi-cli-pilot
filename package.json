{
  "name": "gemini-pilot",
  "version": "1.0.0",
  "description": "Multi-agent orchestration harness for Gemini CLI -- prompts, workflows, and team coordination",
  "author": "Doeon Kim",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "gp": "dist/cli/index.js",
    "gemini-pilot": "dist/cli/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "prompts",
    "workflows",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "yaml": "^2.7.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "keywords": [
    "gemini",
    "gemini-cli",
    "multi-agent",
    "orchestration",
    "ai",
    "workflow",
    "prompt-engineering"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/KIM3310/gemini-pilot"
  }
}
